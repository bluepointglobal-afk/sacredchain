# ---- Server ----
PORT=5000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:3000

# ---- MongoDB Atlas ----
# Get this from your MongoDB Atlas cluster: Connect > Drivers
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/sacred_knowledge?retryWrites=true&w=majority

# ---- JWT ----
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# ---- AI Scholar Companion (Anthropic Claude) ----
# Optional. If omitted, the AI endpoint returns a graceful fallback reply.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
