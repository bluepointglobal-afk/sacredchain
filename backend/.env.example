# ---- Server ----
PORT=5000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:3000
PUBLIC_API_URL=http://localhost:5000

# ---- MongoDB Atlas ----
# Get this from your MongoDB Atlas cluster: Connect > Drivers
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/sacred_knowledge?retryWrites=true&w=majority

# ---- JWT / Auth ----
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=15m
REFRESH_SECRET=change-me-to-another-long-random-string
REFRESH_EXPIRES_IN=30d
COOKIE_DOMAIN=

# ---- AI Scholar Companion (Anthropic Claude) ----
# Optional. If omitted, the AI endpoint returns a graceful fallback reply.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ---- Stripe (payments) ----
# Optional in dev. Without keys, bookings/enrolments fall back to a free/mock flow.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# ---- Email (SMTP via Nodemailer) ----
# Optional. Without SMTP creds, emails are logged to the console (dev mode).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Sacred Knowledge <no-reply@sacredknowledge.app>"

# ---- AWS S3 (file uploads) ----
# Optional. Without these, the upload endpoint returns 503.
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=

# ---- Jitsi (video) ----
JITSI_DOMAIN=meet.jit.si

# ---- Observability ----
SENTRY_DSN=
LOG_LEVEL=info
